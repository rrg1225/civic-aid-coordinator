{
  "name": "civic-aid-coordinator",
  "version": "1.0.0",
  "description": "Full-stack civic aid coordination platform for triaging vulnerable-neighbor requests, matching local resources, and auditing response work.",
  "type": "module",
  "license": "MIT",
  "author": "lixian",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite --host 0.0.0.0",
    "test": "node --test test/*.test.js",
    "build": "vite build",
    "start": "node server/index.js",
    "health": "node scripts/project-health.js"
  },
  "keywords": [
    "civic-tech",
    "mutual-aid",
    "fullstack",
    "react",
    "express",
    "case-management",
    "resource-matching"
  ],
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.4.2"
  }
}
